{
  "cli_default_open_behavior": "existing_window",
  "icon_theme": "Zed (Default)",
  "theme": "Base16",
  "auto-update": false,
  "autosave": {
    "after_delay": {
      "milliseconds": 500
    }
  },
  "buffer_font_family": "JetBrains Mono",
  "buffer_font_size": 16,
  
  "languages": {
    "Nix": {
      "language_servers": [
        "nixd",
        "!nil"
      ]
    }
  },
  "lsp": {
    "nixd": {
      "binary": {
        "path_lookup": true
      }
    },
    "rust-analyzer": {
      "binary": {
        "path_lookup": true
      }
    }
  },
  
  "project_panel": {
    "dock": "left",
    "entry_spacing": "comfortable",
    "sticky_scroll": false
  },
  
  "outline_panel": {
    "dock": "left"
  },
  
  "telemetry": {
    "diagnostics": false,
    "metrics": false
  },
  
  "ui_font_family": "Noto Sans",
  "ui_font_size": 14,
  "vim_mode": false
}